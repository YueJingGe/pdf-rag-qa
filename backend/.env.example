# ============================================================
# PDF RAG 智能问答系统 - 环境配置模板
# ============================================================
# 使用说明：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 按照下方注释获取各 API Key 并填入
#   3. .env 文件已被 .gitignore 排除，不会提交到 Git
# ============================================================

# === LLM 大语言模型配置（RAG 问答 - 必填）===
# DeepSeek API: 访问 https://platform.deepseek.com/api_keys 注册账号后获取
# 免费额度：新用户赠送 500 万 tokens，足够大量测试
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 可选模型：deepseek-chat(默认)、deepseek-v4-flash(更快更便宜，推荐)
DEEPSEEK_MODEL=deepseek-v4-flash

# === 普通聊天模型配置（GLM-4V-Flash - 智谱 AI 免费多模态）===
# 智谱 AI: 访问 https://open.bigmodel.cn/usercenter/apikeys 注册获取 API Key
# 完全免费、不限量，支持图片理解，国内直连无需科学上网
# 如果留空，普通聊天将 fallback 到 DeepSeek（消耗 token）
CHAT_API_KEY=
CHAT_BASE_URL=https://open.bigmodel.cn/api/paas/v4
CHAT_MODEL=glm-4v-flash

# === 文本嵌入模型配置 ===
# 可选值：
#   "huggingface" - 本地模型(bge-small-zh-v1.5)，完全免费，无需 API Key（推荐）
#   "dashscope"   - 阿里云通义千问嵌入(text-embedding-v3)，需要 API Key
EMBEDDING_PROVIDER=huggingface

# DashScope API Key（仅当 EMBEDDING_PROVIDER=dashscope 时需要）
# 获取地址：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=

# HuggingFace 模型配置
# 国内网络必须配置镜像地址，否则无法下载模型
HF_ENDPOINT=https://hf-mirror.com
# 首次运行需联网下载模型（约 400MB），下载完成后设为 1 可离线使用
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0

# === 数据库配置 ===
# 默认使用 SQLite，无需额外安装数据库服务
DATABASE_URL=sqlite+aiosqlite:///./data/db.sqlite3

# === 文件存储路径 ===
UPLOAD_DIR=./data/uploads
FAISS_INDEX_DIR=./data/faiss_indexes

# === RAG 检索参数（可根据实际效果调优）===
# CHUNK_SIZE: 文本分块大小(字符数)，越大上下文越完整但 Token 消耗越高
CHUNK_SIZE=1200
# CHUNK_OVERLAP: 分块重叠字符数，避免关键信息被截断
CHUNK_OVERLAP=150
# RETRIEVAL_TOP_K: 检索返回的最相关文本块数量，越多准确率越高但 Token 越多
RETRIEVAL_TOP_K=4

# === Langfuse 可观测性（可选，留空则禁用）===
# 用于监控 LLM 调用链路、Token 消耗、检索质量等指标
# 获取地址：https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# === 认证配置 ===
# JWT 密钥：生产环境请务必替换为随机长字符串
# 生成方式：openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string

# === OAuth2/SSO（可选，留空则禁用）===
OAUTH2_PROVIDER=
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_AUTHORIZE_URL=
OAUTH2_TOKEN_URL=
OAUTH2_USERINFO_URL=

# === 服务器配置 ===
HOST=0.0.0.0
PORT=8000
